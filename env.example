# ========================================
# SARKIN MOTA AUTOS - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env.local and fill in your actual values

# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Get these from your Supabase project dashboard
# 1. Go to https://supabase.com/dashboard
# 2. Create a new project or select existing one
# 3. Go to Settings > API
# 4. Copy the values below


# ========================================
# CLOUDINARY CONFIGURATION
# ========================================
# Get these from your Cloudinary account
# 1. Go to https://cloudinary.com/users/register/free
# 2. Sign up and verify your email
# 3. Go to Dashboard: https://console.cloudinary.com/
# 4. Copy your Cloud Name, API Key, and API Secret

# Your Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=ddnlbizum
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=ddnlbizum

# Your Cloudinary API key
CLOUDINARY_API_KEY=429619496111619

# Your Cloudinary API secret (keep this secret!)
CLOUDINARY_API_SECRET=avYcbU4PjXgrSscibOJDLImiBd0

# Upload preset for unsigned uploads (optional but recommended)
# Create one in Cloudinary Dashboard > Settings > Upload > Upload presets
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=sarkin-mota-autos

# ========================================
# RESEND EMAIL CONFIGURATION
# ========================================
# Get this from your Resend account
# 1. Go to https://resend.com
# 2. Sign up and create an account
# 3. Go to API Keys section
# 4. Create a new API key

# Your Resend API key for sending emails
RESEND_API_KEY=re_your-resend-api-key-here

# Email address to receive car inquiry emails
# This is where inquiries from the car detail pages will be sent
CONTACT_EMAIL=info@sarkinmotaautos.com

# Optional: Additional email address(es) for CC (Carbon Copy)
# Both recipients will see each other's email addresses
# For multiple emails, separate with commas: email1@example.com,email2@example.com
CONTACT_EMAIL_CC=sales@sarkinmotaautos.com

# Optional: Additional email address(es) for BCC (Blind Carbon Copy)
# Recipients will NOT see each other's email addresses
# For multiple emails, separate with commas: email1@example.com,email2@example.com
# Note: If both CC and BCC are set, BCC will be used (CC will be ignored)
CONTACT_EMAIL_BCC=admin@sarkinmotaautos.com

# Optional: Second BCC email address
# This will be combined with CONTACT_EMAIL_BCC
CONTACT_EMAIL_BCC_2=support@sarkinmotaautos.com

# ========================================
# MESSAGE ENCRYPTION
# ========================================
# Encryption key for end-to-end message encryption
# IMPORTANT: Use a strong, random key (at least 32 characters)
# Generate one using: openssl rand -base64 32
# This key must be the same in both main app and admin app
# Keep this secret and never commit it to git
MESSAGE_ENCRYPTION_KEY=your-strong-random-encryption-key-here-minimum-32-characters
NEXT_PUBLIC_MESSAGE_ENCRYPTION_KEY=your-strong-random-encryption-key-here-minimum-32-characters

# ========================================
# APP CONFIGURATION
# ========================================
# Update these for your specific setup

# Your app's base URL
# For development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp number for contact page
# Format: +234XXXXXXXXXX (include country code with +)
# This will be used when users want to contact via WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=+2340000000000

# ========================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ========================================
# Uncomment and configure these if needed

# Custom domain for emails (optional)
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Database connection pool size (optional)
# SUPABASE_DB_POOL_SIZE=10

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file to .env.local
# 2. Fill in your actual values above
# 3. Never commit .env.local to git
# 4. For production, set these in your hosting platform (Vercel, etc.)

# ========================================
# SUPABASE SETUP STEPS
# ========================================
# 1. Create Supabase project: https://supabase.com/dashboard
# 2. Run the SQL schema from supabase-schema.sql in your SQL editor
# 3. Copy the URL and keys from Settings > API
# 4. Update the values above

# ========================================
# CLOUDINARY SETUP STEPS
# ========================================
# 1. Sign up at https://cloudinary.com/users/register/free
# 2. Verify your email and go to Dashboard
# 3. Copy your Cloud Name, API Key, and API Secret
# 4. (Optional) Create an upload preset:
#    - Go to Settings > Upload > Upload presets
#    - Create new preset: name it "sarkin-mota-autos"
#    - Set to "Unsigned" for client-side uploads
#    - Set folder to "cars/"
#    - Set max file sizes (10MB images, 100MB videos)
# 5. Update the Cloudinary variables above

# ========================================
# RESEND SETUP STEPS
# ========================================
# 1. Sign up at https://resend.com
# 2. Verify your domain (optional but recommended)
# 3. Create an API key
# 4. Update the RESEND_API_KEY above

# ========================================
# PRODUCTION DEPLOYMENT
# ========================================
# When deploying to Vercel or other platforms:
# 1. Set all these environment variables in your hosting platform
# 2. Update NEXT_PUBLIC_APP_URL to your production domain
# 3. Make sure RESEND_FROM_EMAIL is set to a verified domain 